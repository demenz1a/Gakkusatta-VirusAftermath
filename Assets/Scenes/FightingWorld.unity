    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[0]'
      value: "\u2014 Bienvenue \u0432 \u043C\u043E\u0451 \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u043E\u0435
        \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u0442\u0432\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
        Je suis \u041C\u0430\u0448\u0435\u0440\u043E\u043D\u0438, \u0443 \u043B\u044F
        \u043A\u043E\u043D\u0441\u0442\u0430\u043D\u0442 d'\u042D\u0439\u043B\u0435\u0440
        \u2014 \u0440\u0435\u0439\u043D \u0434\u044D\u0437 \u0441\u044C\u043E\u043D\u0441."
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[1]'
      value: "\u2014 \u041C\u0438\u0441\u0441 \u042D\u0439\u043B\u0435\u0440?"
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[2]'
      value: "\u2014 \u041A\u0442\u043E?"
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[3]'
      value: "\u2014 \u041D\u0430\u0448\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u043A\u0430!"
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[4]'
      value: "\u2014 \u041A\u0430\u043A\u0438\u0435 \u043B\u0438\u0446\u0430. \u041C\u0438\u043D\u043E\u0440\u0438,
        \u0432\u0442\u043E\u0440\u0430\u044F \u043F\u043E \u0443\u0441\u043F\u0435\u0432\u0430\u0435\u043C\u043E\u0441\u0442\u0438
        \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043A\u0430 \u0438... \u0442\u0435\u0431\u044F
        \u044F \u0432\u0438\u0436\u0443 \u0432\u043F\u0435\u0440\u0432\u044B\u0435."
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[5]'
      value: "\u2014 \u042F \u0442\u043E\u0436\u0435. \u0420\u0435\u0439\u043A\u043E,
        \u0440\u0430\u0434\u0430 \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u0443."
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[6]'
      value: "\u2014 \u041C\u043D\u0435 \u0436\u0430\u043B\u044C, \u0447\u0442\u043E
        \u043D\u0430\u0448\u0435 \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u043E
        \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u0442 \u0432 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
        \u0441\u0435\u043A\u0443\u043D\u0434\u044B \u0442\u0432\u043E\u0435\u0439
        \u0436\u0438\u0437\u043D\u0438..."
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[7]'
      value: "\u2014 \u042D\u044D... \u0447\u0442\u043E?"
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[8]'
      value: "\u2014 \u0412\u0438\u0434\u0438\u0442\u0435 \u043B\u0438, \u044F \u0442\u043E\u0436\u0435
        \u043F\u043E\u0434\u0432\u0435\u0440\u0433\u043B\u0430\u0441\u044C \u044D\u0442\u043E\u043C\u0443
        \u0432\u0438\u0440\u0443\u0441\u0443, \u043D\u043E \u044F \u043E\u0442\u043B\u0438\u0447\u0430\u044E\u0441\u044C
        \u043E\u0442 \u0442\u0435\u0445 \u0443\u0440\u043E\u0434\u043E\u0432, \u0447\u0442\u043E
        \u0432\u044B \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u043B\u0438 \u0440\u0430\u043D\u0435\u0435."
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[9]'
      value: "\u2014 \u041E\u0442\u043B\u0438\u0447\u0430\u0435\u0442\u0435\u0441\u044C?"
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[10]'
      value: "\u2014 \u0412\u043D\u0443\u0442\u0440\u0438 \u043C\u0435\u043D\u044F
        \u0433\u043E\u0440\u0438\u0442 \u0436\u0435\u043B\u0430\u043D\u0438\u0435...
        \u043D\u0430\u043A\u0430\u0437\u0430\u0442\u044C \u0432\u0441\u0435\u0445,
        \u043A\u0442\u043E \u043D\u0435 \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u0442
        \u043A\u0440\u0430\u0441\u043E\u0442\u044B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438!"
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[11]'
      value: "\u2014 \u0424\u0443."
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[12]'
      value: "\u2014 \u0423 \u0442\u0435\u0431\u044F \u0432\u0441\u0435\u0433\u0434\u0430
        \u0431\u044B\u043B\u0438 \u043D\u0438\u0437\u043A\u0438\u0435 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B,
        \u0420\u0435\u0439\u043A\u043E. \u0418 \u0442\u044B \u043D\u0435 \u043E\u043F\u0440\u0430\u0432\u0434\u0430\u043B\u0430
        \u043C\u043E\u0438\u0445 \u043E\u0436\u0438\u0434\u0430\u043D\u0438\u0439,
        \u041C\u0438\u043D\u043E\u0440\u0438. \u0412\u044B \u043E\u0431\u0435 \u043D\u0435\u0434\u043E\u0441\u0442\u043E\u0439\u043D\u044B
        \u0436\u0438\u0442\u044C, \u043F\u043E\u044D\u0442\u043E\u043C\u0443 \u044F
        \u043F\u043E\u0437\u0430\u0431\u043E\u0447\u0443\u0441\u044C \u043E \u0442\u043E\u043C,
        \u0447\u0442\u043E\u0431\u044B \u0443\u0431\u0438\u0442\u044C \u0432\u0430\u0441."
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[13]'
      value: " \u0418 \u0447\u0442\u043E \u043D\u0430\u043C \u0442\u0435\u043F\u0435\u0440\u044C,
        \u0441 \u041C\u0430\u0441\u043A\u0430\u0440\u043F\u043E\u043D\u0435 \u0434\u0440\u0430\u0442\u044C\u0441\u044F?
        \u041A\u0430\u043A-\u0442\u043E \u043D\u0435 \u043E\u0441\u043E\u0431\u043E
        \u0445\u043E\u0447\u0435\u0442\u0441\u044F \u0431\u0438\u0442\u044C \u0435\u0435..."
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[14]'
      value: "\u2014 \u041C\u043E\u0451 \u0438\u043C\u044F \u2014 \u041C\u0430\u0441\u043A\u0435\u0440\u043E\u043D\u0438."
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[15]'
      value: "\u2014 \u0414\u043E\u043B\u0436\u043D\u0430 \u043F\u0440\u0438\u0437\u043D\u0430\u0442\u044C,
        \u044F \u0443\u0434\u0438\u0432\u043B\u0435\u043D\u0430, \u0447\u0442\u043E
        \u0432\u044B \u0435\u0449\u0451 \u0436\u0438\u0432\u044B. \u041D\u043E \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0430\u044F
        \u0447\u0430\u0441\u0442\u044C \u2014 \u043C\u043E\u044F \u043B\u044E\u0431\u0438\u043C\u0430\u044F."
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[16]'
      value: "\u0423\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F!"
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[17]'
      value: "\u0427\u0442\u043E\u0431\u044B \u0432\u0441\u0451 \u0431\u044B\u043B\u043E
        \u0447\u0435\u0441\u0442\u043D\u043E, \u044F \u0434\u0430\u043C \u0442\u0435\u0431\u0435
        \u0448\u0430\u043D\u0441 \u043D\u0430\u043D\u0435\u0441\u0442\u0438 \u043C\u043D\u0435
        \u0443\u0440\u043E\u043D."
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[18]'
      value: "\u0415\u0441\u043B\u0438 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442
        \u0431\u0443\u0434\u0435\u0442 \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C
        \u2014 \u0443\u0440\u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0443 \u044F."
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[19]'
      value: "\u041D\u043E \u0435\u0441\u043B\u0438 \u043E\u043D \u0431\u0443\u0434\u0435\u0442
        \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C
        \u2014 \u0443\u0440\u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u0448\u044C
        \u0442\u044B."
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[20]'
      value: "\u0412\u044B\u0431\u0435\u0440\u0438 \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0439
        \u0431\u043B\u043E\u043A, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0437\u0430\u043C\u0435\u043D\u0438\u0442
        \u0445. \u0418 \u043F\u043E\u043C\u043D\u0438... \u041E\u0442 \u0442\u0432\u043E\u0435\u0433\u043E
        \u043E\u0442\u0432\u0435\u0442\u0430 \u0437\u0430\u0432\u0438\u0441\u0438\u0442
        \u0442\u0432\u043E\u044F \u0436\u0438\u0437\u043D\u044C!"
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
      propertyPath: 'lines.Array.data[21]'
      value: "\u2014 \u042F \u0434\u043E\u043B\u0436\u043D\u0430 \u0443\u0431\u0438\u0432\u0430\u0442\u044C
        \u0442\u0435\u0445, \u043A\u0442\u043E \u043D\u0435 \u0441\u043E\u0432\u043F\u0430\u0434\u0430\u0435\u0442
        \u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439...
        \u043D\u043E \u044F \u043E\u043F\u043E\u0440\u043E\u0447\u0438\u043B\u0430
        \u0435\u0435 \u0447\u0435\u0441\u0442\u044C... \u043A\u0430\u043A \u0436\u0430\u043B\u044C."
      objectReference: {fileID: 0}
    - target: {fileID: 5174575025459245558, guid: 86a74390b94467f46bb610d14306f5de, type: 3}
