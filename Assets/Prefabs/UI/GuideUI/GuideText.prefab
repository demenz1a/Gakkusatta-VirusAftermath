  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0412\u0441\u0435\u043C \u043F\u0440\u0438\u0432\u0435\u0442, \u043D\u0430
    \u0441\u0432\u044F\u0437\u0438 \u0421\u0430\u043B\u043C\u043E\u043D \u0422\u0438\u043C.
    \u0410 \u044D\u0442\u043E \u043A\u0440\u0430\u0442\u043A\u0438\u0439 \u0433\u0430\u0439\u0434
    \u043F\u043E \u0434\u0435\u043C\u043E-\u0432\u0435\u0440\u0441\u0438\u0438. \r\n\r\n\u0421\u043E\u0432\u0435\u0442\u0443\u044E
    \u043D\u0435 \u0441\u043A\u0438\u043F\u0430\u0442\u044C \u0433\u0430\u0439\u0434,
    \u043E\u0434\u043D\u0430\u043A\u043E, \u0435\u0441\u043B\u0438 \u0445\u043E\u0442\u0438\u0442\u0435
    - \u043D\u0430\u0436\u043C\u0438\u0442\u0435 \u043D\u0430 Enter.\r\n\r\n\u0418\u0442\u0430\u043A,
    \u043F\u0435\u0440\u0432\u0430\u044F \u0430\u0442\u0430\u043A\u0430: \u043D\u0430
    \u043F\u043E\u043B\u0443 \u0431\u0443\u0434\u0443\u0442 \u043F\u043E\u044F\u0432\u043B\u044F\u0442\u044C\u0441\u044F
    \u0442\u043E\u0447\u043A\u0438, \u0430 \u043C\u0435\u0436\u0434\u0443 \u043D\u0438\u043C\u0438
    - \u043B\u0438\u043D\u0438\u044F. \u0412\u044B \u0434\u043E\u043B\u0436\u043D\u044B
    \u0443\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u0442\u044C\u0441\u044F
    \u043E\u0442 \u043E\u0442\u0440\u0435\u0437\u043A\u043E\u0432, \u0438\u043D\u0430\u0447\u0435
    \u0431\u0443\u0434\u0435\u0442 \u0431\u043E\u043B\u044C\u043D\u043E.\r\n\r\n\u0412\u0442\u043E\u0440\u0430\u044F
    \u0430\u0442\u0430\u043A\u0430: \u041D\u0430\u0439\u0442\u0438 \u0445. \u041C\u0430\u0441\u043A\u0435\u0440\u043E\u043D\u0438
    \u043D\u0430\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0435\u0442 \u0445 \u043D\u0430
    \u0420\u0435\u0439\u043A\u043E. \u041D\u0443\u0436\u043D\u043E \u0443\u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F
    \u0432 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439 \u043C\u043E\u043C\u0435\u043D\u0442,
    \u0447\u0442\u043E\u0431\u044B \u0438\u0437\u0431\u0435\u0436\u0430\u0442\u044C
    \u0443\u0440\u043E\u043D\u0430.\r\n\r\n\u0422\u0440\u0435\u0442\u044C\u044F:
    \u0442\u0430\u043D\u0435\u0446 \u0433\u0440\u0430\u0444\u0438\u043A\u043E\u0432.
    \u041C\u0430\u0441\u043A\u0435\u0440\u043E\u043D\u0438 \u0431\u0443\u0434\u0435\u0442
    \u0442\u0430\u043D\u0446\u0435\u0432\u0430\u0442\u044C, \u0438 \u043D\u0430 \u043F\u043E\u043B\u0435
    \u0431\u0443\u0434\u0443\u0442 \u043F\u043E\u044F\u0432\u043B\u044F\u0442\u044C\u0441\u044F
    \u0433\u0440\u0430\u0444\u0438\u043A\u0438, \u0441\u043E\u0432\u043F\u0430\u0434\u0430\u044E\u0449\u0438\u0435
    \u0441 \u0440\u0430\u0441\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435\u043C
    \u0435\u0435 \u0440\u0443\u043A. \u0418 \u0441\u043D\u043E\u0432\u0430 - \u0443\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u0439\u0442\u0435\u0441\u044C!\r\n\r\n\u0427\u0435\u0442\u0432\u0435\u0440\u0442\u0430\u044F:
    \u041C\u0430\u0441\u043A\u0435\u0440\u043E\u043D\u0438 \u0441\u043E\u0437\u0434\u0430\u0435\u0442
    \u0444\u0438\u0433\u0443\u0440\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0441\u0442\u0440\u0435\u043C\u044F\u0442\u0441\u044F \u0437\u0430\u0445\u0432\u0430\u0442\u0438\u0442\u044C
    \u0420\u0435\u0439\u043A\u043E. \u0423\u0431\u0435\u0433\u0430\u0439\u0442\u0435,
    \u0447\u0442\u043E\u0431\u044B \u043D\u0435 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u0443\u0440\u043E\u043D.\r\n\r\n\u0418 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u044F\u044F,
    \u0441\u0430\u043C\u0430\u044F \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u0430\u044F
    \u0430\u0442\u0430\u043A\u0430 - \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F,
    \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0432\u044B \u0441\u043C\u043E\u0436\u0435\u0442\u0435 \u043D\u0430\u043D\u0435\u0441\u0442\u0438
    \u0443\u0440\u043E\u043D \u041C\u0430\u0441\u043A\u0435\u0440\u043E\u043D\u0438!\r\n\r\n\u041C\u0430\u0441\u043A\u0435\u0440\u043E\u043D\u0438
    \u0441\u043E\u0437\u0434\u0430\u0435\u0442 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435
    \u0441 \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u044E\u0449\u0438\u043C \u0445,
    \u0430 \u0442\u0430\u043A \u0436\u0435 \u0442\u0440\u0438 \u0432\u0430\u0440\u0438\u0430\u043D\u0442\u0430
    \u0445. \u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u043E\u0434\u0438\u043D
    \u0438\u0437 \u043D\u0438\u0445, \u0438 \u044D\u0442\u043E\u0442 \u0432\u044B\u0431\u043E\u0440
    \u043F\u043E\u0432\u043B\u0438\u044F\u0435\u0442 \u043D\u0430 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F.\r\n\r\n\u0415\u0441\u043B\u0438
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439,
    \u0443\u0440\u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442 \u0420\u0435\u0439\u043A\u043E.
    \u0410 \u0435\u0441\u043B\u0438 \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    - \u041C\u0430\u0441\u043A\u0435\u0440\u043E\u043D\u0438. \r\n\r\n\u041D\u0430\u0434\u0435\u0435\u043C\u0441\u044F,
    \u0447\u0442\u043E \u0432\u0441\u0435 \u043F\u043E\u043D\u044F\u0442\u043D\u043E.
    \u041F\u043E\u0432\u0435\u0441\u0435\u043B\u0438\u0442\u0435\u0441\u044C!"
