--- !u!114 &5174575025459245558
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 5586571056947319340}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 861fc0170af5b5743b65baed0b0e6285, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  lines:
  - "\u2014 \u0425\u043E\u0447\u0443 \u043F\u0438\u0442\u044C..."
  - "\u2014 \u041A\u0442\u043E \u044D\u0442\u043E?!"
  - " \u2014 \u041A\u0430\u043A \u0445\u043E\u0440\u043E\u0448\u043E, \u0447\u0442\u043E
    \u044F \u0432\u0441\u0435\u0433\u0434\u0430 \u0442\u0430\u0441\u043A\u0430\u044E
    \u0441 \u0441\u043E\u0431\u043E\u0439 \u043A\u0430\u0442\u0430\u043D\u0443."
  - "\u2014 \u0423\u0440\u0433\u0445, \u0434\u0430\u0439\u0442\u0435 \u0445\u043E\u0442\u044C
    \u043F\u043E\u043F\u0438\u0442\u044C."
  - "\u2014 \u041B\u0443\u0447\u0448\u0435 \u0431\u044B \u044F \u0443\u043C\u0435\u0440\u043B\u0430..."
  - "\u2014 \u0427\u0442\u043E \u0442\u044B \u0437\u0434\u0435\u0441\u044C \u0434\u0435\u043B\u0430\u0435\u0448\u044C?"
  - "\u2014 \u0414\u0430 \u0432\u043E\u0442, \u0433\u0430\u0437\u0438\u0440\u043E\u0432\u043A\u0443
    \u043F\u044C\u044E."
  - "\u2014 \u0422\u0435\u0431\u044F \u043D\u0435 \u0431\u044B\u043B\u043E \u0432\u0435\u0441\u044C
    \u0441\u0435\u043C\u0435\u0441\u0442\u0440, \u0438 \u0442\u044B \u0440\u0435\u0448\u0438\u043B\u0430
    \u0437\u0430\u044F\u0432\u0438\u0442\u044C\u0441\u044F \u0438\u043C\u0435\u043D\u043D\u043E
    \u0441\u0435\u0433\u043E\u0434\u043D\u044F?"
  - "\u2014 \u0427\u0442\u043E \u044D\u0442\u043E \u0437\u0430 \u0436\u0435\u0441\u0442\u044C
    \u0432\u043E\u043E\u0431\u0449\u0435?"
  - "\u2014 \u042F \u0438 \u0441\u0430\u043C\u0430 \u043D\u0435 \u0437\u043D\u0430\u044E,
    \u043D\u043E \u0432\u0438\u0434\u0438\u043C\u043E \u044D\u0442\u043E \u043A\u0430\u043A\u043E\u0435
    \u0442\u043E \u0437\u0430\u0440\u0430\u0436\u0435\u043D\u0438\u0435..."
  - "\u2014 \u041E\u0439,\u0430 \u044F \u043F\u0430\u0440\u043E\u0447\u043A\u0443
    \u0437\u0430\u0440\u0443\u0431\u0438\u043B\u0430..."
  - "\u2014 \u041A\u0445\u043C. \u041D\u043E \u043D\u0438\u0447\u0435\u0433\u043E
    \u043E\u0441\u043E\u0431\u043E \u0438 \u043D\u0435 \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u043E\u0441\u044C,
    \u043E\u043D\u0438 \u0442\u0430\u043A\u0438\u0435 \u0436\u0435 \u0442\u0443\u043F\u0438\u0446\u044B. "
  - "\u2014 \u0422\u043E\u0447\u043D\u043E, \u0442\u0435\u0431\u0435 \u0436\u0435
    \u0432\u0441\u0451 \u0440\u0430\u0432\u043D\u043E."
  - "\u2014 \u0427\u0451\u0440\u0442, \u043A\u0430\u0436\u0435\u0442\u0441\u044F,
    \u0435\u0449\u0451 \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0430\u044E\u0442\u0441\u044F."
  - "\u2014 \u0423\u0445, \u043D\u0443 \u043B\u0430\u0434\u043D\u043E."
  - "\u2014 \u0417\u0434\u0435\u0441\u044C \u043D\u0435\u043B\u044C\u0437\u044F \u043E\u0441\u0442\u0430\u0432\u0430\u0442\u044C\u0441\u044F
    \u0434\u043E\u043B\u0433\u043E, \u043D\u0430\u0434\u043E \u0432\u044B\u0431\u0438\u0440\u0430\u0442\u044C\u0441\u044F."
  - "\u2014 \u0412 \u0430\u043A\u0442\u043E\u0432\u043E\u043C \u0437\u0430\u043B\u0435
    \u0435\u0441\u0442\u044C \u0432\u044B\u0445\u043E\u0434 \u043D\u0430\u0440\u0443\u0436\u0443,
    \u043D\u0430\u043C \u043D\u0443\u0436\u043D\u043E \u0442\u0443\u0434\u0430. "
  characterNames:
